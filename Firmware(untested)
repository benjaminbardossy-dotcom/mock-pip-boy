void in_sensors(){ //Display temperature, humidity, and air pressure readings from the AHT20+BMP280
  display.setCursor(5, yMid-(smallTextSize*2));
  sensors_event_t humidity, temp, temp_event, pressure_event;

  display.clearDisplay();
  aht.getEvent(&humidity, &temp); // populate temp and humidity objects with fresh data
  display.setCursor(0, 40);
  display.print("Temp: ");
  display.print(temp.temperature);
  display.println(" C");
  display.setCursor(0, 60);
  display.print("Hum: ");
  display.print(humidity.relative_humidity);
  display.println(" %");

  bmp_temp->getEvent(&temp_event);
  bmp_pressure->getEvent(&pressure_event);
  
  display.print(F("BMP 280 Temperature = "));
  display.print(temp_event.temperature);
  display.println(" *C");

  display.print(F("Pressure = "));
  display.print(pressure_event.pressure);
  display.println(" hPa");
  display.display();
  
  yield();

  checkReturn();
}

void in_heart(){ //Display heart rate, and blood O2 level if possible
  display.setCursor(5, yMid-10);
  long irValue = particleSensor.getIR();

  if (checkForBeat(irValue) == true)
  {
    //We sensed a beat!
    long delta = millis() - lastBeat;
    lastBeat = millis();

    beatsPerMinute = 60 / (delta / 1000.0);

    if (beatsPerMinute < 255 && beatsPerMinute > 20)
    {
      rates[rateSpot++] = (byte)beatsPerMinute; //Store this reading in the array
      rateSpot %= RATE_SIZE; //Wrap variable

      //Take average of readings
      beatAvg = 0;
      for (byte x = 0 ; x < RATE_SIZE ; x++)
        beatAvg += rates[x];
      beatAvg /= RATE_SIZE;
    }
  }

  display.clearDisplay();
  //display.print("IR=");
  //display.print(irValue);
  display.print("BPM=");
  display.println(beatsPerMinute);
  display.print(" Avg BPM=");
  display.println(beatAvg);

  if (irValue < 50000)    display.println(" No finger");
  display.display();

  checkReturn();
}

void in_screenSaver(){ //Display cool animations on the OLED
  playAnim(); // Seperate functions for different animations which the play can scroll through
  checkReturn();
}


struct Drop{
  int x;
  int y;
  int speed; //Added for varying speeds within animations
};

void playAnim(){
  const int numDrops = 60;
  Drop drops[numDrops];

  int delayLength = 20; //Make this variable alterable through the rotary encoder 

  bool shouldPlay = true;

  unsigned long currentMillis = millis();

  for (int k = 0; k < numDrops; k++) { //setup drops
    drops[k].x = random(0, SCREEN_WIDTH);
    drops[k].y = random(-60, 0);  // start somewhere offscreen for variety
    drops[k].speed = 2;
  }

  while (shouldPlay) {
    unsigned long currentMillis = millis();
    // Only update and redraw when delayLength ms have passed
    if (currentMillis - previousMillis_Anim >= delayLength) {
      previousMillis_Anim = currentMillis;

      display.clearDisplay();
      for (int k = 0; k < numDrops; k++) {
        checkReturn();
        display.drawPixel(drops[k].x, drops[k].y, 1);
        drops[k].y += drops[k].speed;           // move down
        if (drops[k].y >= SCREEN_HEIGHT) {      // reset when off‑screen
          drops[k].y = random(-30, 0);          // start somewhere offscreen for variety
          drops[k].x = random(0, SCREEN_WIDTH);
        }
      }
      display.display();
    }

    // Your other code (e.g. rotary encoder reading) can run here
    // without being blocked by delay():
    // checkRotaryEncoder(); // example
  }
}

void checkReturn(){ // function since this is called often
  if(BB_val == 0 && lastBB_val == 1){ //Return to main menu
    currentState = mainMenu;
    display.clearDisplay(); //Reset oled screen
  }
}

