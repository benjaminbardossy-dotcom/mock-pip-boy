void in_distance(){ //Display distance readings from the VL53L0X **Add the ability to freeze measurements at the press of a button
  digitalWrite(laserPin, HIGH); //Turn laser on
  
  VL53L0X_RangingMeasurementData_t measure;

  lox.rangingTest(&measure, false); // pass in 'true' to get debug data printout

  if (measure.RangeStatus != 4) {  // phase failures have correct data
    display.setCursor(xMid-15, yMid-(smallTextSize*2));
    display.clearDisplay();
    display.print(measure.RangeMilliMeter);
    display.print("mm");
    display.display();
  } 
  else {
    display.setCursor(xMid-25, yMid-(smallTextSize*2)); // tweaked text position since the text is longer
    display.clearDisplay();
    display.print("Too Far!");
    display.display();
    //return;
  }

  checkReturn();
}

