void setup() {
  Serial.begin(115200);

  pinMode(buttonDown, INPUT_PULLUP);
  pinMode(buttonUp, INPUT_PULLUP);
  pinMode(buttonBack, INPUT_PULLUP);
  pinMode(buttonSelect, INPUT_PULLUP);

  if (!lox.begin()) {
    Serial.println(F("Failed to boot VL53L0X"));
    while(1);
  }

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println(F("Failed to boot display"));
    while(1);
  }

  // Initialize sensor
  if (!particleSensor.begin(Wire, 0x3)) //Use default I2C port, 400kHz speed
  {
    Serial.println("MAX30105 was not found. Please check wiring/power. ");
    while (1);
  }
  particleSensor.setup(); //Configure sensor with default settings


  if (!aht.begin()) {
    Serial.println("Didn't find AHT20");
    while(1);
  }

  if(!bmp.begin()){
    Serial.println("Didn't find BMP280");
    while(1);
  }

  /* Default settings from datasheet. */
  bmp.setSampling(Adafruit_BMP280::MODE_NORMAL,     /* Operating Mode. */
                  Adafruit_BMP280::SAMPLING_X2,     /* Temp. oversampling */
                  Adafruit_BMP280::SAMPLING_X16,    /* Pressure oversampling */
                  Adafruit_BMP280::FILTER_X16,      /* Filtering. */
                  Adafruit_BMP280::STANDBY_MS_500); /* Standby time. */

  //bmp_temp->printSensorDetails();

  
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(0, 0);
  display.display();
}

void loop() {
  lastBD_val = BD_val;
  lastBU_val = BU_val;
  lastBB_val = BB_val;
  lastBS_val = BS_val;

  BD_val = digitalRead(buttonDown);
  BU_val = digitalRead(buttonUp);
  BB_val = digitalRead(buttonBack);
  BS_val = digitalRead(buttonSelect);

  if(currentState != distance){
    digitalWrite(laserPin, switchPin);
  }

  switch(currentState){
    case mainMenu: in_mainMenu();
      display.display();
      break;

    case settings: in_settings();
      display.display();
      break;

    case distance: in_distance();
      display.display();
      break;

    case airQuality: in_airQuality();
      display.display();
      break;

    case heart: in_heart();
      display.display();
      break;

    case sensors: in_sensors();
      display.display();
      break;

    case screenSaver: in_screenSaver();
      //No display since handling it is more complex in animations;
      break;
  }
}

void in_mainMenu(){ //Main menu for scrolling through the other menu options

  if(BU_val == 0 && lastBU_val == 1 && currentSelection < (sizeof(menuNames) / sizeof(menuNames[0])) - 1){
    currentSelection++;
    display.clearDisplay(); //Reset oled screen
  }
  if(BD_val == 0 && lastBD_val == 1 && currentSelection > 0)
  {
    currentSelection--;
    display.clearDisplay(); //Reset oled screen
  }
  
  display.setCursor(5, yMid-(smallTextSize*2));
  display.print(currentSelection+1);
  display.print(". ");
  display.print(menuNames[currentSelection]);

  if(BS_val == 0 && lastBS_val == 1){
    currentState = static_cast<State>(currentSelection); //Convert the integer associated with currentSelection to the enum State through casting
    display.clearDisplay(); //Reset oled screen
  }
}

